# ── Database ────────────────────────────────────────────────────────────────────
# PostgreSQL connection string.
# For Supabase: use the session-pooler URL (port 5432, not 6543).
# pgBouncer transaction mode (port 6543) breaks SQLAlchemy persistent connections.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Clerk Authentication ────────────────────────────────────────────────────────
# JWKS endpoint used by fastapi-clerk-auth to validate Clerk JWTs.
# Find it in Clerk Dashboard → API Keys → Advanced → JWKS URL.
# Format: https://clerk.<your-domain>.com/.well-known/jwks.json
CLERK_JWKS_URL=https://clerk.your-domain.com/.well-known/jwks.json

# ── CORS ────────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. In production set to your Vercel URL.
# Multiple origins: https://your-app.vercel.app,https://your-custom-domain.com
CORS_ORIGINS=http://localhost:3000

# ── OpenAI ──────────────────────────────────────────────────────────────────────
# Optional. Without this key the app runs in demo mode with mock AI responses.
# Users can also supply their own key via the Settings page (sent per-request).
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
